# Makevars.in for ACFcuda

# config file now sets CUDA_HOME, CUDA_INCLUDE, CUDA_LIB, and CUDA_STUBS
# if they are not already set
PKG_CPPFLAGS = -I. -I@CUDA_INCLUDE@

PKG_LIBS = -L@CUDA_LIB@ -lcudart \
           -L@CUDA_STUBS@ -lcuda \
           -Wl,-rpath,@CUDA_LIB@

# C source files (compiled by R's default CC, typically gcc on non-macOS devices)
SOURCES_C = buffers.c \
            command.c \
            devices.c \
            libraries_functions.c \
            runners.c \
            utils.c \
            R_init_ACFcuda.c

# CUDA source files (compiled by nvcc, then linked)
# none for now, and realistically, I'm not sure we should be shipping any?

# Object files for both sets
OBJECTS_C  = $(SOURCES_C:.c=.o)
# for now we aren't sending kernels along, but if we do, this helps us
# avoid name conflicts
# OBJECTS_CU = $(SOURCES_CU:.cu=_cu.o)

OBJECTS = $(OBJECTS_C)

# nvcc flags:
#   -O2 == optimize
#   -Xcompiler == pass flags through to the host compiler
#   -fPIC == required for shared objects
#   --std=c++11 == nvcc wraps C++ even for extern "C" translation units
#   -I. == find ACFcuda.h from src/
#   -I$(CUDA_INCLUDE) == find cuda_runtime.h
# NVCC_FLAGS = -O2 -Xcompiler -fPIC --std=c++11 -I. -I$(CUDA_INCLUDE)

# should we need this ...
# rule: compile each .cu into a _cu.o object via nvcc
# %_cu.o: %.cu
# 	$(NVCC) $(NVCC_FLAGS) -c $< -o $@
